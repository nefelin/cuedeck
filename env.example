# Auth.js — generate with: openssl rand -base64 32
# REQUIRED on Vercel Production (not just .env.local). Redeploy after adding.
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Add redirect URI: https://cuedeck-xi.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Neon Postgres — from Vercel Marketplace → Neon integration
DATABASE_URL=
